# Copiar a .env.local y completar (NUNCA commitear .env.local)
# Neon central compartida (copiar el valor desde Vercel del selector)
DATABASE_URL=

# Secret PROPIO de FEBO-GESTION para firmar la sesión (cualquier string random largo,
# no tiene que coincidir con el del selector). Generar uno y poner el mismo en Vercel.
FG_JWT_SECRET=

# Llamadas entre apps (mismo del selector)
INTERNAL_SERVICE_SECRET=

# Facturación AFIP (mismos del selector, fase posterior)
ARCA_CERT_PEM=
ARCA_KEY_PEM=
ARCA_CUIT=
